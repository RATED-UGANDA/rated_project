PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_NAME=ratedug

JWT_SECRET=replace_with_a_strong_random_string_in_production
JWT_EXPIRES_IN=7d

# Ollama Cloud chat endpoint (used by validation and rewrite services)
# For Ollama Cloud use https://api.ollama.com/api/chat
# For a local Ollama instance use http://localhost:11434/api/chat
LLM_API_URL=https://api.ollama.com/api/chat
LLM_API_KEY=your_ollama_api_key_here
LLM_MODEL=deepseek-v4-flash

# Scraper / image refresh intervals
SCRAPE_INTERVAL_MINUTES=60
IMAGE_REFRESH_HOURS=24

# Pexels stock image API
PEXELS_API_KEY=your_pexels_api_key_here
